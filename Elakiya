<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>T. Elakkiya | Portfolio</title>
<style>
:root{
  --bg-0:#07050c;
  --bg-1:#0f0a1a;
  --panel:rgba(255,255,255,0.05);
  --panel-border:rgba(168,85,247,0.25);
  --purple-1:#a855f7;
  --purple-2:#7c3aed;
  --purple-3:#d946ef;
  --neon:#c084fc;
  --text-0:#f4f0fb;
  --text-1:#b9aed1;
  --font-display:'Space Grotesk', 'Segoe UI', sans-serif;
  --font-body:'Outfit','Segoe UI', sans-serif;
}
[data-theme="light"]{
  --bg-0:#f6f2fb;
  --bg-1:#ece3fb;
  --panel:rgba(124,58,237,0.06);
  --panel-border:rgba(124,58,237,0.25);
  --text-0:#1c1226;
  --text-1:#4b3866;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  background:var(--bg-0);
  color:var(--text-0);
  font-family:var(--font-body);
  overflow-x:hidden;
  cursor:none;
  transition:background .4s ease,color .4s ease;
}
@font-face{font-family:'Space Grotesk';src:local('Arial');}
h1,h2,h3,.display{font-family:var(--font-display);letter-spacing:.5px;}

/* ---------- custom cursor ---------- */
.cursor-dot,.cursor-ring{
  position:fixed;top:0;left:0;pointer-events:none;z-index:9999;
  border-radius:50%;transform:translate(-50%,-50%);
}
.cursor-dot{width:8px;height:8px;background:var(--purple-3);box-shadow:0 0 10px var(--purple-3);}
.cursor-ring{width:34px;height:34px;border:1px solid var(--purple-1);opacity:.7;transition:width .2s,height .2s,border-color .2s;}
.cursor-ring.active{width:54px;height:54px;border-color:var(--purple-3);}
@media(max-width:768px){.cursor-dot,.cursor-ring{display:none;}body{cursor:auto;}}

/* ---------- background canvas ---------- */
#bg-canvas{position:fixed;inset:0;z-index:0;background:radial-gradient(ellipse at 20% 20%,#1a0f2e 0%,var(--bg-0) 60%);}

/* ---------- scrollbar ---------- */
::-webkit-scrollbar{width:8px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:linear-gradient(var(--purple-2),var(--purple-3));border-radius:10px;}

/* ---------- intro ---------- */
#intro{
  position:fixed;inset:0;z-index:1000;
  background:radial-gradient(ellipse at 50% 40%,#20123a 0%,#07050c 70%);
  display:flex;align-items:center;justify-content:center;flex-direction:column;
  transition:opacity 1s ease, visibility 1s ease;
}
#intro.hide{opacity:0;visibility:hidden;pointer-events:none;}
.intro-eyebrow{
  font-size:.8rem;letter-spacing:6px;text-transform:uppercase;color:var(--purple-1);margin-bottom:18px;
  opacity:0;animation:riseIn .8s ease forwards .2s;
}
#typed-name{
  font-family:var(--font-display);font-size:clamp(2.2rem,8vw,5rem);font-weight:700;
  background:linear-gradient(90deg,#fff,var(--neon),var(--purple-2));
  -webkit-background-clip:text;background-clip:text;color:transparent;
  text-shadow:0 0 40px rgba(168,85,247,.35);
  min-height:1.2em;
}
.typed-cursor{display:inline-block;width:3px;background:var(--purple-3);margin-left:4px;animation:blink 1s step-end infinite;box-shadow:0 0 8px var(--purple-3);}
.intro-sub{margin-top:16px;color:var(--text-1);opacity:0;animation:riseIn .8s ease forwards 2.6s;font-size:.95rem;letter-spacing:1px;}
@keyframes blink{50%{opacity:0;}}
@keyframes riseIn{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
.intro-skip{
  position:absolute;bottom:40px;font-size:.75rem;color:var(--text-1);letter-spacing:2px;text-transform:uppercase;
  border:1px solid var(--panel-border);padding:10px 22px;border-radius:30px;background:var(--panel);backdrop-filter:blur(10px);
  opacity:0;animation:riseIn .8s ease forwards 3s;
}

/* ---------- nav ---------- */
#navbar{
  position:fixed;top:22px;left:50%;transform:translateX(-50%);z-index:500;
  display:flex;gap:4px;padding:10px 12px;border-radius:40px;
  background:var(--panel);border:1px solid var(--panel-border);backdrop-filter:blur(18px);
  box-shadow:0 8px 32px rgba(0,0,0,.35);
  transition:top .4s ease, opacity .4s ease;
}
#navbar a{
  color:var(--text-1);text-decoration:none;font-size:.82rem;padding:9px 16px;border-radius:30px;
  position:relative;transition:color .3s ease;white-space:nowrap;
}
#navbar a.active,#navbar a:hover{color:#fff;background:linear-gradient(135deg,var(--purple-2),var(--purple-3));box-shadow:0 0 18px rgba(168,85,247,.5);}
#theme-toggle{
  margin-left:6px;border:none;background:var(--panel);border:1px solid var(--panel-border);
  color:var(--text-0);width:36px;height:36px;border-radius:50%;cursor:none;font-size:1rem;
}
@media(max-width:900px){
  #navbar{max-width:94vw;overflow-x:auto;justify-content:flex-start;}
  #navbar a{padding:8px 12px;font-size:.72rem;}
}

/* ---------- sections ---------- */
section{position:relative;z-index:2;padding:130px 8vw 90px;min-height:100vh;display:flex;flex-direction:column;justify-content:center;}
.eyebrow{color:var(--purple-1);letter-spacing:4px;text-transform:uppercase;font-size:.78rem;margin-bottom:14px;}
.sec-title{font-size:clamp(2rem,5vw,3.2rem);margin-bottom:40px;}
.sec-title span{background:linear-gradient(90deg,var(--neon),var(--purple-2));-webkit-background-clip:text;background-clip:text;color:transparent;}

/* ---------- home ---------- */
#home{align-items:center;text-align:center;}
.home-photo-wrap{
  width:190px;height:190px;border-radius:50%;margin:0 auto 30px;position:relative;
}
.home-photo-wrap img{
  width:100%;height:100%;object-fit:cover;border-radius:50%;
  border:2px solid var(--purple-1);box-shadow:0 0 40px rgba(168,85,247,.5),0 0 80px rgba(217,70,239,.25);
}
.home-photo-wrap::before{
  content:'';position:absolute;inset:-10px;border-radius:50%;border:1px dashed var(--purple-3);opacity:.5;
  animation:spin 14s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg);}}
#home h1{font-size:clamp(2.4rem,7vw,4.6rem);margin-bottom:10px;}
#home h1 span{background:linear-gradient(90deg,#fff,var(--neon),var(--purple-2));-webkit-background-clip:text;background-clip:text;color:transparent;}
.home-role{font-size:1.1rem;color:var(--text-1);min-height:1.6em;margin-bottom:34px;}
.home-role .bar{display:inline-block;width:2px;background:var(--purple-3);margin-left:3px;animation:blink 1s step-end infinite;}
.btn-row{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;}
.btn{
  padding:14px 30px;border-radius:30px;border:1px solid var(--panel-border);text-decoration:none;
  color:var(--text-0);font-size:.9rem;letter-spacing:.5px;position:relative;overflow:hidden;transition:transform .3s ease;
}
.btn.primary{background:linear-gradient(135deg,var(--purple-2),var(--purple-3));box-shadow:0 0 24px rgba(168,85,247,.45);border:none;color:#fff;}
.btn:hover{transform:translateY(-4px);}
.scroll-cue{margin-top:70px;color:var(--text-1);font-size:.7rem;letter-spacing:3px;text-transform:uppercase;}
.scroll-cue .dot-line{width:1px;height:40px;background:linear-gradient(var(--purple-2),transparent);margin:10px auto 0;animation:pulseLine 2s ease infinite;}
@keyframes pulseLine{0%,100%{opacity:.3;}50%{opacity:1;}}

/* ---------- glass card ---------- */
.glass{
  background:var(--panel);border:1px solid var(--panel-border);border-radius:20px;
  backdrop-filter:blur(16px);box-shadow:0 8px 30px rgba(0,0,0,.25);
}

/* ---------- about ---------- */
.about-grid{display:grid;grid-template-columns:1.1fr 1.4fr;gap:50px;align-items:start;}
@media(max-width:900px){.about-grid{grid-template-columns:1fr;}}
.about-card{padding:34px;}
.about-card p{color:var(--text-1);line-height:1.85;margin-bottom:16px;font-size:.98rem;}
.about-card p b{color:var(--text-0);}
.family-list{list-style:none;margin-top:18px;}
.family-list li{
  display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px dashed var(--panel-border);color:var(--text-1);font-size:.92rem;
}
.family-list li span{color:var(--text-0);font-weight:600;}
.goal-badge{
  display:inline-flex;align-items:center;gap:10px;margin-top:22px;padding:12px 20px;border-radius:14px;
  background:linear-gradient(135deg,rgba(168,85,247,.15),rgba(217,70,239,.1));border:1px solid var(--panel-border);
}
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:30px;}
.stat{padding:22px 10px;text-align:center;}
.stat .num{font-family:var(--font-display);font-size:2.1rem;background:linear-gradient(90deg,var(--neon),var(--purple-2));-webkit-background-clip:text;background-clip:text;color:transparent;}
.stat .label{font-size:.75rem;color:var(--text-1);letter-spacing:1px;text-transform:uppercase;margin-top:4px;}

/* ---------- skills ---------- */
.skills-wrap{display:grid;gap:24px;max-width:760px;}
.skill-item{padding:22px 26px;}
.skill-top{display:flex;justify-content:space-between;margin-bottom:12px;font-size:.95rem;}
.skill-top .pct{color:var(--purple-1);font-weight:600;}
.bar-track{height:10px;border-radius:10px;background:rgba(255,255,255,.06);overflow:hidden;}
.bar-fill{
  height:100%;border-radius:10px;width:0%;
  background:linear-gradient(90deg,var(--purple-2),var(--neon));
  box-shadow:0 0 12px rgba(192,132,252,.6);
  transition:width 1.6s cubic-bezier(.16,1,.3,1);
}

/* ---------- projects ---------- */
.projects-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:26px;}
.project-card{
  padding:28px;position:relative;overflow:hidden;transition:transform .4s ease,box-shadow .4s ease;
}
.project-card:hover{transform:translateY(-10px);box-shadow:0 20px 50px rgba(168,85,247,.25);}
.earth{
  width:60px;height:60px;border-radius:50%;margin-bottom:18px;
  background:radial-gradient(circle at 30% 30%,#3ddc97,#1a4d7a 40%,#0c1b2e 100%);
  box-shadow:0 0 25px rgba(61,220,151,.35), inset -8px -8px 16px rgba(0,0,0,.5);
  animation:rotateEarth 6s linear infinite;
  position:relative;
}
@keyframes rotateEarth{
  0%{background-position:0 0;}
  100%{background-position:60px 0;}
}
.earth::after{
  content:'';position:absolute;inset:0;border-radius:50%;
  background:repeating-linear-gradient(100deg, transparent 0 8px, rgba(61,220,151,.5) 8px 10px, transparent 10px 20px);
  animation:spin 5s linear infinite;opacity:.6;
}
.project-card h3{margin-bottom:8px;font-size:1.15rem;}
.project-card p{color:var(--text-1);font-size:.88rem;line-height:1.6;margin-bottom:18px;}
.project-counts{display:flex;gap:20px;margin-bottom:20px;}
.project-counts div{text-align:center;}
.project-counts .n{font-family:var(--font-display);font-size:1.4rem;color:var(--neon);}
.project-counts .l{font-size:.68rem;color:var(--text-1);text-transform:uppercase;letter-spacing:1px;}
.open-btn{
  display:inline-block;padding:10px 22px;border-radius:24px;font-size:.8rem;color:#fff;text-decoration:none;
  background:linear-gradient(135deg,var(--purple-2),var(--purple-3));box-shadow:0 0 0 rgba(168,85,247,0);
  transition:box-shadow .3s ease, transform .3s ease;
}
.project-card:hover .open-btn{box-shadow:0 0 22px rgba(168,85,247,.6);transform:translateY(-2px);}

/* ---------- timeline ---------- */
.timeline{position:relative;max-width:720px;margin-top:20px;padding-left:30px;}
.timeline::before{content:'';position:absolute;left:6px;top:0;bottom:0;width:2px;background:linear-gradient(var(--purple-2),transparent);}
.tl-item{
  position:relative;padding:24px 26px;margin-bottom:26px;opacity:0;transform:translateX(-30px);
  transition:opacity .8s ease,transform .8s ease;
}
.tl-item.show{opacity:1;transform:translateX(0);}
.tl-item::before{
  content:'';position:absolute;left:-30px;top:28px;width:14px;height:14px;border-radius:50%;
  background:var(--purple-3);box-shadow:0 0 14px var(--purple-3);
}
.tl-year{color:var(--purple-1);font-size:.8rem;letter-spacing:2px;margin-bottom:6px;font-weight:600;}
.tl-item h3{font-size:1.1rem;margin-bottom:6px;}
.tl-item p{color:var(--text-1);font-size:.88rem;}

/* ---------- certificates ---------- */
.cert-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;}
.cert-card{padding:30px;text-align:center;transition:transform .4s ease;}
.cert-card:hover{transform:translateY(-8px) rotate(-1deg);}
.cert-icon{font-size:2.4rem;margin-bottom:14px;filter:drop-shadow(0 0 12px rgba(168,85,247,.6));}
.cert-card h3{margin-bottom:6px;}
.cert-card p{color:var(--text-1);font-size:.85rem;}

/* ---------- contact ---------- */
.contact-wrap{max-width:560px;padding:40px;text-align:center;}
.contact-wrap p{color:var(--text-1);margin-bottom:26px;line-height:1.7;}
.insta-btn{
  display:inline-flex;align-items:center;gap:10px;padding:14px 30px;border-radius:30px;text-decoration:none;color:#fff;
  background:linear-gradient(135deg,#833ab4,#c13584,#e1306c);box-shadow:0 0 30px rgba(193,53,132,.45);font-size:.95rem;
  transition:transform .3s ease;
}
.insta-btn:hover{transform:translateY(-4px) scale(1.03);}

/* ---------- extra features section ---------- */
.feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;}
.feat-card{padding:26px;text-align:center;}
.feat-card .ic{font-size:1.6rem;margin-bottom:12px;}
.feat-card h4{font-size:.92rem;margin-bottom:6px;}
.feat-card p{font-size:.78rem;color:var(--text-1);}

/* ---------- footer ---------- */
footer{position:relative;z-index:2;text-align:center;padding:34px;color:var(--text-1);font-size:.78rem;letter-spacing:1px;}

/* ---------- back to top ---------- */
#backTop{
  position:fixed;bottom:30px;right:30px;z-index:400;width:48px;height:48px;border-radius:50%;
  background:var(--panel);border:1px solid var(--panel-border);backdrop-filter:blur(10px);color:var(--text-0);
  display:flex;align-items:center;justify-content:center;cursor:none;opacity:0;pointer-events:none;
  transition:opacity .4s ease,transform .4s ease;box-shadow:0 0 20px rgba(168,85,247,.3);
}
#backTop.show{opacity:1;pointer-events:auto;}
#backTop:hover{transform:translateY(-4px);box-shadow:0 0 26px rgba(168,85,247,.6);}

.reveal{opacity:0;transform:translateY(30px);transition:opacity .8s ease,transform .8s ease;}
.reveal.show{opacity:1;transform:translateY(0);}
</style>
</head>
