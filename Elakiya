<!-- EXTRA FEATURES -->
<section id="features">
  <div class="eyebrow">Under the hood</div>
  <h2 class="sec-title">Extra <span>Features</span></h2>
  <div class="feat-grid">
    <div class="feat-card glass"><div class="ic">🌗</div><h4>Dark / Light Mode</h4><p>Switch themes anytime</p></div>
    <div class="feat-card glass"><div class="ic">🧈</div><h4>Smooth Scrolling</h4><p>Buttery section transitions</p></div>
    <div class="feat-card glass"><div class="ic">🔢</div><h4>Animated Counters</h4><p>Numbers that count up</p></div>
    <div class="feat-card glass"><div class="ic">🧭</div><h4>Floating Navbar</h4><p>Always within reach</p></div>
    <div class="feat-card glass"><div class="ic">✨</div><h4>Particle Background</h4><p>Ambient animated canvas</p></div>
    <div class="feat-card glass"><div class="ic">⬆️</div><h4>Back To Top</h4><p>One click to the top</p></div>
    <div class="feat-card glass"><div class="ic">🖱️</div><h4>Custom Cursor</h4><p>Neon glow cursor effects</p></div>
